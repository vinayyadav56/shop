# Staging environment — copy to .env.staging.local and fill in secrets
# Run: yarn dev:rest (starts on port 3003)
NEXT_PUBLIC_VERSION=REST
FRAMEWORK_PROVIDER=rest
APPLICATION_MODE=staging
NEXT_PUBLIC_REST_API_ENDPOINT=https://plantathome-production.up.railway.app
NEXT_PUBLIC_SITE_URL=https://plantathome-shop-staging.vercel.app
NEXT_PUBLIC_ADMIN_URL=https://plantathome-admin-staging.vercel.app
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_ENABLE_MULTI_LANG=false
NEXT_PUBLIC_AVAILABLE_LANGUAGES=en
