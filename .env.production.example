# Production environment — values injected by GitHub Actions; this is documentation only
# Secrets stored as GitHub Actions Secrets (never committed)
NEXT_PUBLIC_VERSION=REST
FRAMEWORK_PROVIDER=rest
APPLICATION_MODE=production
NEXT_PUBLIC_REST_API_ENDPOINT=https://api.plantathome.in/api
NEXT_PUBLIC_SITE_URL=https://plantathome.in
NEXT_PUBLIC_ADMIN_URL=https://admin.plantathome.in
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_REPLACE_ME  # GitHub Secret: PROD_RAZORPAY_KEY_ID
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_ENABLE_MULTI_LANG=false
NEXT_PUBLIC_AVAILABLE_LANGUAGES=en
NODE_ENV=production
