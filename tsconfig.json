{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/framework/*": ["./src/framework/rest/*"],
      "react-query": ["./src/compat/react-query"],
      "react-query/hydration": ["./src/compat/react-query-hydration"],
      "next-i18next": ["./src/compat/next-i18next"],
      "next-i18next/serverSideTranslations": ["./src/compat/next-i18next"],
      "react-i18next": ["./src/compat/next-i18next"],
      "next/router": ["./src/compat/next-router"],
      "next-seo": ["./src/compat/next-seo"],
      "next-auth/react": ["./src/compat/next-auth-react"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
